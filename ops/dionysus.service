[Unit]
Description=Dionysus Platekit SaaS
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/dionysus
EnvironmentFile=/opt/dionysus/.env
ExecStart=/opt/dionysus/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8450
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
