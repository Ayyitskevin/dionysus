DIONYSUS_ENV=production
DIONYSUS_SECRET_KEY=change-me
DIONYSUS_DATA_DIR=/opt/dionysus/data
DIONYSUS_BASE_URL=https://platekit.example.com
DIONYSUS_COOKIE_SECURE=true
DIONYSUS_MISE_IMPORT_TOKEN=
# Homelab studio (no Stripe): see ops/homelab.env.example and scripts/deploy-homelab.sh
# Mise Argus callback also POSTs /api/mise/organizations/{slug}/argus-pack to draft packs.
# Plutus homelab POSTs /api/mise/organizations/{slug}/print-pitch for pitch.txt enrichment.
# Optional Argus run enrichment when generating packs (argus_run_id on generate form).
DIONYSUS_WORKER_POLL_SECONDS=2
DIONYSUS_JOB_STALE_SECONDS=900
# DIONYSUS_ARGUS_URL=http://mickey:8010
# DIONYSUS_ARGUS_API_TOKEN=
DIONYSUS_STRIPE_SECRET_KEY=sk_test_or_live
DIONYSUS_STRIPE_WEBHOOK_SECRET=whsec_from_stripe
DIONYSUS_STRIPE_PRICE_RESTAURANT_STARTER=price_restaurant_starter
DIONYSUS_STRIPE_PRICE_RESTAURANT_GROWTH=price_restaurant_growth
DIONYSUS_STRIPE_PRICE_PHOTOGRAPHER_STUDIO=price_photographer_studio
