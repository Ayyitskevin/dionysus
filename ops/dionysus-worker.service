[Unit]
Description=Dionysus Platekit worker
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/dionysus
EnvironmentFile=/opt/dionysus/.env
ExecStart=/opt/dionysus/.venv/bin/python -m app.cli worker --poll 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
